SECRET_KEY=change-me-to-a-random-string
DATABASE_PATH=/data/vulnapps.db
TOKEN_EXPIRY_HOURS=24

# ── scanimport.sh ────────────────────────────────────────────
# Vulnapps target instance
VULNAPPS_URL=https://vulnapps.example.com
VULNAPPS_API_KEY=va_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API (used by the importer for finding-to-vuln mapping)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Or, use Vertex instead of the Anthropic API:
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=my-gcp-project
# ANTHROPIC_VERTEX_LOCATION=us-east5

# Only needed when importing with --probely
# PROBELY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
